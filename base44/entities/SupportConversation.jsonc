{
  "name": "SupportConversation",
  "type": "object",
  "properties": {
    "customer_email": {
      "type": "string",
      "description": "Email of the customer"
    },
    "customer_name": {
      "type": "string",
      "description": "Name of the customer"
    },
    "status": {
      "type": "string",
      "enum": [
        "open",
        "closed"
      ],
      "default": "open",
      "description": "Conversation status"
    },
    "last_message": {
      "type": "string",
      "description": "Preview of last message"
    },
    "last_message_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp of last message"
    },
    "unread_by_admin": {
      "type": "boolean",
      "default": true,
      "description": "Whether admins have unread messages"
    }
  },
  "required": [
    "customer_email"
  ],
  "rls": {
    "create": null,
    "read": {
      "$or": [
        {
          "data.customer_email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}